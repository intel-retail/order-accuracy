FROM python:3.10-slim

RUN apt-get update && apt-get install -y \
    libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY app/requirements.txt .
# Install CPU-only torch 2.6.0+ (fixes CVE-2025-32434) first
# torch>=2.6.0 must be installed before nncf to prevent nncf pulling an older version
# Use --extra-index-url (not --index-url) so PyPI stays available for typing-extensions etc.
RUN pip install --no-cache-dir torch==2.6.0+cpu torchvision==0.21.0+cpu \
    --extra-index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir -r requirements.txt

COPY app /app

CMD ["python", "frame_selector.py"]
